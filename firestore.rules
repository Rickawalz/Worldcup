rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function configuredAdminEmail() {
      return 'rgw1985@hotmail.com';
    }

    function privateAccountEmail(userId) {
      return get(/databases/$(database)/documents/users/$(userId)/private/account).data;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || request.auth.token.email == configuredAdminEmail()
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/private/account)
          && (
            privateAccountEmail(request.auth.uid).authEmail == configuredAdminEmail()
            || privateAccountEmail(request.auth.uid).email == configuredAdminEmail()
          )
        )
      );
    }

    function contestConfigPath() {
      return /databases/$(database)/documents/globalContest/current/config/current;
    }

    function contestConfigData() {
      return get(contestConfigPath()).data;
    }

    function lockAtTimestamp() {
      let raw = contestConfigData().lockAt;
      return raw is timestamp
        ? raw
        : timestamp.value(
            raw is string && !raw.matches('.*Z$') && !raw.matches('.*[+-][0-9]{2}:[0-9]{2}$')
              ? raw + 'Z'
              : raw
          );
    }

    // Match admin contest settings: accepting submissions ON and before lock time.
    function submissionsOpen() {
      return exists(contestConfigPath())
        && (
          !('isAcceptingSubmissions' in contestConfigData())
          || contestConfigData().isAcceptingSubmissions == true
        )
        && ('lockAt' in contestConfigData())
        && request.time < lockAtTimestamp();
    }

    function validUsername(username) {
      return username is string
        && username.matches('^[A-Za-z0-9_]{3,20}$');
    }

    function hasUserProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function chatMessageCoreUnchanged() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.username == resource.data.username
        && request.resource.data.text == resource.data.text
        && request.resource.data.isEdited == resource.data.isEdited
        && request.resource.data.isDeleted == resource.data.isDeleted
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function canReactToChatMessage() {
      let uid = request.auth.uid;
      let before = resource.data.get('reactionsByUser', {});
      let after = request.resource.data.get('reactionsByUser', {});
      let beforeMine = before.get(uid, []);
      let afterMine = after.get(uid, []);
      let addedOne = afterMine.hasAll(beforeMine)
        && afterMine.size() == beforeMine.size() + 1;
      let removedOne = beforeMine.hasAll(afterMine)
        && beforeMine.size() == afterMine.size() + 1;
      return signedIn()
        && hasUserProfile()
        && !resource.data.isDeleted
        && chatMessageCoreUnchanged()
        && request.resource.data.reactionsByUser is map
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactionsByUser', 'updatedAt'])
        && after.diff(before).affectedKeys().hasOnly([uid])
        && afterMine is list
        && beforeMine is list
        && (addedOne || removedOne);
    }

    function canEditOwnChatMessage() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.username == resource.data.username
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSelf(userId)
        && validUsername(request.resource.data.username);
      allow update: if isSelf(userId)
        || isAdmin();
      allow delete: if false;

      match /private/{document=**} {
        allow read, write: if isSelf(userId)
          || isAdmin();
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.authEmail is string
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.authEmail is string
        && resource.data.userId is string
        && !exists(/databases/$(database)/documents/users/$(resource.data.userId));
      allow delete: if false;
    }

    match /countries/{countryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fixtures/{fixtureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /standings/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /globalContest/{contestId}/config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /globalContest/{contestId}/officialResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /globalContest/{contestId}/brackets/{userId} {
      allow read: if true;
      allow create, update: if isSelf(userId)
        && submissionsOpen()
        && request.resource.data.status in ['draft', 'submitted'];
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /leaderboards/global/entries/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /globalChat/{messageId} {
      allow read: if true;
      allow create: if signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow update: if canReactToChatMessage() || canEditOwnChatMessage();
      allow delete: if false;
    }

    match /adminOverrides/{overrideId} {
      allow read, write: if isAdmin();
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /syncState/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
